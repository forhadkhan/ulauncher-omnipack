{
  "required_api_version": "^2.0.0",
  "name": "OmniPack",
  "description": "All-in-one productivity extension for uLauncher",
  "developer_name": "Forhad Khan",
  "icon": "images/icon.svg",
  "options": {
    "query_debounce": 0.1
  },
  "preferences": [
    {
      "id": "omni_kw",
      "type": "keyword",
      "name": "OmniPack",
      "description": "Main trigger keyword",
      "default_value": "omni"
    },
    {
      "id": "enabled_modules",
      "type": "select",
      "name": "Active Module Groups",
      "description": "Enable/disable feature categories",
      "default_value": "all",
      "options": [
        {"value": "all", "text": "All"},
        {"value": "dev", "text": "Developer Tools"},
        {"value": "system", "text": "System Utilities"},
        {"value": "web", "text": "Web Search"},
        {"value": "utils", "text": "Utilities"}
      ]
    },
    {
      "id": "uuid_kw",
      "type": "keyword",
      "name": "UUID Generator",
      "default_value": "uuid"
    },
    {
      "id": "pass_kw",
      "type": "keyword",
      "name": "Password Generator",
      "default_value": "pass"
    },
    {
      "id": "kill_kw",
      "type": "keyword",
      "name": "Kill Process",
      "default_value": "kill"
    },
    {
      "id": "killport_kw",
      "type": "keyword",
      "name": "Kill Port",
      "default_value": "killport"
    },
    {
      "id": "emptytrash_kw",
      "type": "keyword",
      "name": "Empty Trash",
      "default_value": "emptytrash"
    },
    {
      "id": "ai_aggregator_kw",
      "type": "keyword",
      "name": "AI Aggregator",
      "description": "Links to Perplexity, Gemini, ChatGPT, etc.",
      "default_value": "ai"
    },
    {
      "id": "ai_kw",
      "type": "keyword",
      "name": "Google AI Mode",
      "description": "Google Search with AI results (udm=50)",
      "default_value": "gai"
    },
    {
      "id": "google_kw",
      "type": "keyword",
      "name": "Google Search",
      "default_value": "g"
    },
    {
      "id": "file_search_kw",
      "type": "keyword",
      "name": "File Search",
      "default_value": "f"
    },
    {
      "id": "file_search_path",
      "type": "input",
      "name": "File Search Path",
      "description": "Default directory to search in (e.g. ~/Documents)",
      "default_value": "~"
    },
    {
      "id": "calc_kw",
      "type": "keyword",
      "name": "Calculator",
      "default_value": "calc"
    },
    {
      "id": "youtube_kw",
      "type": "keyword",
      "name": "YouTube Search",
      "default_value": "yt"
    },
    {
      "id": "ip_kw",
      "type": "keyword",
      "name": "IP Lookup",
      "default_value": "ip"
    }
  ]
}